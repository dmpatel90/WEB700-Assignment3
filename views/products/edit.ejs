<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<title>Edit Product</title>

<link rel="stylesheet" href="/css/styles.css">

</head>

<body>

<div class="container">

<h1>Edit Product</h1>

<% if(errors.length>0){ %>

<div class="errors">

<ul>

<% errors.forEach(error=>{ %>

<li><%= error %></li>

<% }) %>

</ul>

</div>

<% } %>

<form action="/products/<%= product.id %>/update" method="POST">

<label>Name</label>

<input
type="text"
name="name"
value="<%= product.name %>"
>

<br><br>

<label>Category</label>

<input
type="text"
name="category"
value="<%= product.category %>"
>

<br><br>

<label>Brand</label>

<input
type="text"
name="brand"
value="<%= product.brand %>"
>

<br><br>

<label>Price</label>

<input
type="number"
step="0.01"
name="price"
value="<%= product.price %>"
>

<br><br>

<label>Stock Quantity</label>

<input
type="number"
name="stockQuantity"
value="<%= product.stockQuantity %>"
>

<br><br>

<label>

<input
type="checkbox"
name="available"
<%= product.available ? "checked" : "" %>
>

Available

</label>

<br><br>

<button class="btn" type="submit">

Update Product

</button>

<a class="btn" href="/products">

Cancel

</a>

</form>

</div>

</body>
</html>