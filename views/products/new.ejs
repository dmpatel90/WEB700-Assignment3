<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Product</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

<div class="container">

<h1>Add Product</h1>

<% if(errors.length > 0){ %>

<div class="errors">
    <ul>
        <% errors.forEach(error=>{ %>
            <li><%= error %></li>
        <% }) %>
    </ul>
</div>

<% } %>

<form action="/products" method="POST">

<label>Name</label>

<input
type="text"
name="name"
value="<%= values.name || '' %>"
>

<br><br>

<label>Category</label>

<input
type="text"
name="category"
value="<%= values.category || '' %>"
>

<br><br>

<label>Brand</label>

<input
type="text"
name="brand"
value="<%= values.brand || '' %>"
>

<br><br>

<label>Price</label>

<input
type="number"
step="0.01"
name="price"
value="<%= values.price || '' %>"
>

<br><br>

<label>Stock Quantity</label>

<input
type="number"
name="stockQuantity"
value="<%= values.stockQuantity || '' %>"
>

<br><br>

<label>

<input
type="checkbox"
name="available"
<%= values.available ? "checked" : "" %>
>

Available

</label>

<br><br>

<button class="btn" type="submit">
Create Product
</button>

<a class="btn" href="/products">
Cancel
</a>

</form>

</div>

</body>
</html>